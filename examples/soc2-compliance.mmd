    style Assessment fill:#FFF3E0,stroke:#F5A623
    style Reporting fill:#E8F5E9,stroke:#4CAF50
    style GapAnalysis fill:#FFF9C4,stroke:#F5A623
    style ReadinessCheck fill:#FFF9C4,stroke:#F5A623
    style AuditorFindings fill:#FFF9C4,stroke:#F5A623
    style Critical fill:#FFCDD2,stroke:#E53935
    style Major fill:#FFE0B2,stroke:#FB8C00
    style Minor fill:#FFF9C4,stroke:#FBC02D
