flowchart LR
    Start(["Me in a\nTechnical Interview"]) --> Split

    Split{"What tools\ndo you use?"}

    Split -->|"Professional Answer"| Interview
    Split -->|"Honest Answer"| Reality

    subgraph Interview["What I Tell Interviewers"]
        direction TB
        I1["Neovim with\nCustom Config"]:::fancy --> I2["Tmux + Custom\nDotfiles"]:::fancy
        I2 --> I3["Docker Compose\nfor Everything"]:::fancy
        I3 --> I4["Kubernetes\nLocal Cluster"]:::fancy
        I4 --> I5["Custom CI/CD\nPipeline Scripts"]:::fancy
        I5 --> I6["Prometheus +\nGrafana Monitoring"]:::fancy
        I6 --> I7["I read RFCs\nfor fun"]:::fancy
    end

    subgraph Reality["What Actually Happens at 2 AM"]
        direction TB
        R1["VS Code with\n47 Extensions"]:::real --> R2["console.log\nDriven Development"]:::real
        R2 --> R3["Copy from\nStack Overflow"]:::real
        R3 --> R4["Ask ChatGPT to\nExplain My Own Code"]:::real
        R4 --> R5["Refresh localhost\n200 Times"]:::real
        R5 --> R6["Google: 'How to\nexit Vim'"]:::real
        R6 --> R7["git push --force\nand Pray"]:::real
    end

    Interview --> Result1(["Hired!\nSenior Engineer"]):::success
    Reality --> Result2(["App Works\nSomehow"]):::success

    R3 -.->|"Ctrl+C, Ctrl+V"| Works["It works but\nI don't know why"]:::mystery
    R4 -.->|"AI explains"| AlsoWorks["Now I sort of\nknow why"]:::mystery
    R6 -.->|":q! :q! :wq!"| StillStuck["Opens nano\ninstead"]:::mystery

    I1 -.->|"Reality check"| R1
    I7 -.->|"Actually reads"| Memes["Reddit\nr/ProgrammerHumor"]:::real

    classDef fancy fill:#6366f1,stroke:#4338ca,color:#fff,font-weight:bold
    classDef real fill:#f97316,stroke:#c2410c,color:#fff,font-weight:bold
    classDef success fill:#22c55e,stroke:#15803d,color:#fff,font-weight:bold
    classDef mystery fill:#a855f7,stroke:#7e22ce,color:#fff,font-weight:bold
